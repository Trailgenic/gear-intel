{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "functions": { "api/**/*.ts": { "maxDuration": 60, "includeFiles": "migrations/**" } },
  "crons": [
    { "path": "/api/jobs/freshness", "schedule": "0 13 * * 1" },
    { "path": "/api/jobs/discovery", "schedule": "0 14 * * 3" },
    { "path": "/api/jobs/evidence", "schedule": "0 15 * * *" }
  ],
  "headers": [{
    "source": "/api/(.*)",
    "headers": [
      { "key": "X-Content-Type-Options", "value": "nosniff" },
      { "key": "Cache-Control", "value": "no-store" }
    ]
  }]
}
